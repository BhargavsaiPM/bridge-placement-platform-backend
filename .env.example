# ===== Bridge Backend Environment Variables =====
# Copy this file to .env and fill values as needed.
# For LOCAL development: these are OPTIONAL (defaults are built-in via application-local.properties)
# For CLOUD deployment: set SPRING_PROFILES_ACTIVE=prod and fill ALL values below.

# Profile (local / prod)
SPRING_PROFILES_ACTIVE=local

# JWT Secret (REQUIRED for production, must be 32+ characters)
JWT_SECRET=your-production-secret-key-at-least-32-characters

# Database
SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/Bridge_PlacementSystem
SPRING_DATASOURCE_USERNAME=postgres
SPRING_DATASOURCE_PASSWORD=root

# Email (for OTP / password reset)
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-password

# Cloudinary (for file uploads in production)
CLOUDINARY_CLOUD_NAME=Root
CLOUDINARY_API_KEY=493227565556278
CLOUDINARY_API_SECRET=cAhuXVMy9TZeMh2YVwIL4WCC7kc

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:5173
